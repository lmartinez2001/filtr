{
  "name": "FILTR environment - CUDA 11.3",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "runArgs": [
    "--gpus",
    "all",
    "--shm-size=8g"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/bin/python3.8"
      }
    }
  },
  "remoteUser": "filtr-user",
  "workspaceFolder": "/workspaces/filtr",
  "mounts": [],
  "updateRemoteUserUID": true
}
